# Copy to .env, fill in values (Supabase → Project Settings → API), then run:
#   npm run env:gen
# That writes supabase-env.js for the browser. Use the anon key only — never service_role.
# Commit supabase-env.js after changes so your deployed site (GitHub Pages, etc.) can reach Supabase.

SUPABASE_URL=
SUPABASE_ANON_KEY=
